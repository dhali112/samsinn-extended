+          if (notices.length > 0) parts.push(`${notices.length} rapid-change notice${notices.length === 1 ? '' : 's'}`)
+          ev.textContent = parts.join(' · ')
+          body.appendChild(ev)
+        }
+        if (evs.length === 0) {
+          const ev = document.createElement('div')
+          ev.style.opacity = '0.6'
