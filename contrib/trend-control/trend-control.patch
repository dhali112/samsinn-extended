+          ev.textContent = `▲ ${alarms.length} alarm${alarms.length === 1 ? '' : 's'} — ${alarms.slice(0, 2).map(e => e.text).join(' · ')}${alarms.length > 2 ? ' …' : ''}`
+          body.appendChild(ev)
+        }
